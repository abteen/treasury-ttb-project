# Copy to .env and fill in values

# Required
ANTHROPIC_API_KEY=your_api_key_here

# Optional overrides
VISION_BACKEND=anthropic          # "anthropic" is the only supported backend currently
ANTHROPIC_MODEL=claude-opus-4-5   # Override the default model
AUDIT_LOG_PATH=logs/audit.jsonl   # Path to the append-only audit log
